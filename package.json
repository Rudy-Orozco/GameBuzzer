{
  "name": "backend-monitor",
  "version": "1.0.0",
  "main": "monitor.js",
  "bin": "monitor.js",
  "type": "commonjs",
  "scripts": {
    "start": "node monitor.js",
    "build": "cd client && npm run build",
    "package": "cd client && npm run build && cd .. && pkg monitor.js --targets node18-win-x64 --output GameController.exe",
    "dist": "npm run package && echo Done! Zip GameController.exe, cloudflared.exe, and the game/ folder"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "socket.io": "^4.7.4"
  },
  "pkg": {
    "assets": [],
    "scripts": [
      "server.js",
      "core/state.js",
      "core/buzzer.js",
      "core/players.js",
      "routes/session.js",
      "routes/teams.js"
    ],
    "targets": ["node18-win-x64"],
    "outputPath": "./"
  }
}
